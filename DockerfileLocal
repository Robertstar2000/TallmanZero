# Use the pre-built latest image for A0
FROM agent0ai/agent-zero:latest

# Set BRANCH to "local"
ARG BRANCH=local
ENV BRANCH=$BRANCH

# Copy current development files to git
# The image's internal scripts will move these to /a0 at runtime.
COPY ./ /git/agent-zero

# Pre-run the installation steps to bake in as much as possible
RUN bash /ins/install_A0.sh $BRANCH

# Expose ports
EXPOSE 22 80 9000-9009

RUN chmod +x /exe/initialize.sh /exe/run_A0.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh

# Use the original initialization script
CMD ["/exe/initialize.sh", "local"]
