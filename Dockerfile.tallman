# =============================================================================
# Tallman Zero - Custom Swarm Image
# =============================================================================
# This Dockerfile bakes local changes (UI, Knowledge) into the official image
# for deployment on the Tallman Docker Swarm.
# =============================================================================

FROM agent0ai/agent-zero:latest

ENV HF_HOME=/opt/huggingface
ENV SENTENCE_TRANSFORMERS_HOME=/opt/sentence_transformers

# Copy updated Web UI
COPY ./webui /a0/webui

# Copy updated Backend Code
COPY ./api /a0/api
COPY ./extensions /a0/extensions
COPY ./helpers /a0/helpers
COPY ./plugins /a0/plugins
COPY ./agent.py /a0/agent.py
COPY ./models.py /a0/models.py
COPY ./initialize.py /a0/initialize.py

# Copy persistent Knowledge files
COPY ./knowledge /a0/knowledge

# Preload a real small local embedding model into the image.
RUN mkdir -p "$HF_HOME" "$SENTENCE_TRANSFORMERS_HOME" \
    && python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2', cache_folder='/opt/sentence_transformers')"

# Ensure permissions are correct
RUN chmod -R 755 /a0/webui /a0/knowledge /a0/extensions /opt/huggingface /opt/sentence_transformers

# Metadata
LABEL maintainer="Tallman Equipment"
LABEL version="1.1.0"
LABEL description="Tallman Zero - Agentic AI Orchestration Platform"
