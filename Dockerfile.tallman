# =============================================================================
# Tallman Zero - Custom Swarm Image
# =============================================================================
# This Dockerfile bakes local changes (UI, Knowledge) into the official image
# for deployment on the Tallman Docker Swarm.
# =============================================================================

FROM agent0ai/agent-zero:latest

# Copy updated Web UI
COPY ./webui /a0/webui

# Copy updated Backend Code
COPY ./api /a0/api
COPY ./helpers /a0/helpers
COPY ./plugins /a0/plugins
COPY ./agent.py /a0/agent.py
COPY ./models.py /a0/models.py
COPY ./initialize.py /a0/initialize.py

# Override self_update_manager to use port 3190 instead of 80
# (Port 80 conflicts with Traefik in Docker Swarm)
COPY ./docker/run/fs/exe/self_update_manager.py /exe/self_update_manager.py

# Copy persistent Knowledge files and User Settings
COPY ./knowledge /a0/knowledge
COPY ./usr /a0/usr

# Ensure permissions are correct
RUN chmod -R 755 /a0/webui /a0/knowledge /a0/usr

# Metadata
LABEL maintainer="Tallman Equipment"
LABEL version="1.1.0"
LABEL description="Tallman Zero - Agentic AI Orchestration Platform"
